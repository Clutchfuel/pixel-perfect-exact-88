# Copy to .dev.vars for local dev (gitignored):
#   bun run setup   OR   node scripts/setup.mjs
#
# Cloudflare production: set the same keys in the Worker dashboard
# (Settings → Variables and Secrets). Never commit .dev.vars.

# --- Client (Vite — exposed to browser, must be VITE_ prefixed) ---
# Required in CI builds; optional locally (falls back to Lovable preview URL)
VITE_SITE_URL=https://clutchfuel.com
# Optional GA4 measurement ID (e.g. G-XXXXXXXXXX) — loads only after cookie consent
VITE_GA_MEASUREMENT_ID=
# Turnstile site key — must be paired with TURNSTILE_SECRET_KEY (both or neither)
VITE_TURNSTILE_SITE_KEY=

# --- Server only (Worker — never prefix with VITE_) ---
# Required in production (skipped in dev/CI when empty)
RESEND_API_KEY=
# Must be a verified sender in Resend; onboarding@resend.dev works for testing
RESEND_FROM_EMAIL=onboarding@resend.dev
# Inbox that receives internal lead notification emails
LEADS_TO_EMAIL=hello@clutchfuel.com
# Required when VITE_TURNSTILE_SITE_KEY is set
TURNSTILE_SECRET_KEY=
# Optional webhook for structured error reports (JSON POST)
ERROR_WEBHOOK_URL=

# Optional token for GET /api/admin/export-leads?token=...
LEADS_EXPORT_TOKEN=

# Clutch Score submit sends TWO emails when RESEND_API_KEY is set:
#   1. User — formatted results (score, opportunity, First Clutch Move, product link)
#   2. Team — internal lead notification to LEADS_TO_EMAIL
#
# Persistence: bind D1 as LEADS_DB in wrangler.jsonc and run migrations in /migrations
# Distributed rate limiting: create a KV namespace and bind as RATE_LIMIT_KV in wrangler.jsonc
