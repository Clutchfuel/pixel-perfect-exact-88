# Copy to .dev.vars for local dev (gitignored):
#   cp .dev.vars.example .dev.vars
#
# Cloudflare production: set the same keys in the Worker dashboard
# (Settings → Variables and Secrets). Never commit .dev.vars.

# --- Client (Vite — exposed to browser, must be VITE_ prefixed) ---
# Required in CI builds; optional locally (falls back to Lovable preview URL)
VITE_SITE_URL=https://pixel-perfect-exact-88.lovable.app
# Optional GA4 measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=
# Optional Cloudflare Turnstile site key (enables bot protection on forms when set)
VITE_TURNSTILE_SITE_KEY=

# --- Server only (Worker — never prefix with VITE_) ---
# Get from https://resend.com/api-keys — leave empty in dev to skip email (forms still succeed)
RESEND_API_KEY=
# Must be a verified sender in Resend; onboarding@resend.dev works for testing
RESEND_FROM_EMAIL=onboarding@resend.dev
# Inbox that receives internal lead notification emails
LEADS_TO_EMAIL=hello@clutchfuel.com
# Optional Turnstile secret (required when VITE_TURNSTILE_SITE_KEY is set)
TURNSTILE_SECRET_KEY=

# Clutch Score submit sends TWO emails when RESEND_API_KEY is set:
#   1. User — formatted quiz results (score, profile, tips, product link)
#   2. Team — internal lead notification to LEADS_TO_EMAIL
