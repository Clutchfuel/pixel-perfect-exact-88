# Copy to .env for local dev. In Lovable, set these under Project → Settings → Environment.
# Never commit .env — the anon key is public by design but belongs in env config only.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# Optional — defaults to https://pixel-perfect-exact-88.lovable.app
# VITE_SITE_URL=
