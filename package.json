{
  "name": "clutchfuel-website",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite dev",
    "setup": "node scripts/setup.mjs",
    "build": "vite build",
    "postbuild": "node scripts/postbuild-server-entry.mjs && node scripts/merge-wrangler-bindings.mjs",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "deploy": "node scripts/ci-build.mjs && wrangler deploy --config wrangler.jsonc",
    "lint": "eslint . --max-warnings 50",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.25.5",
